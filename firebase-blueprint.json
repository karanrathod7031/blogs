{
  "entities": {
    "Post": {
      "title": "Blog Post",
      "description": "A single blog post entry for the portfolio.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the blog post."
        },
        "slug": {
          "type": "string",
          "description": "A URL-friendly version of the title."
        },
        "content": {
          "type": "string",
          "description": "The main content of the post in Markdown format."
        },
        "excerpt": {
          "type": "string",
          "description": "A short summary of the post."
        },
        "authorId": {
          "type": "string",
          "description": "The UID of the author."
        },
        "authorName": {
          "type": "string",
          "description": "The display name of the author."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the post was last updated."
        },
        "published": {
          "type": "boolean",
          "description": "Whether the post is visible to the public."
        },
        "tags": {
          "type": "array",
          "description": "List of tags associated with the post."
        }
      },
      "required": [
        "title",
        "slug",
        "content",
        "authorId",
        "createdAt",
        "updatedAt",
        "published"
      ]
    },
    "User": {
      "title": "User Profile",
      "description": "Public profile information for authors.",
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string"
        },
        "photoURL": {
          "type": "string"
        },
        "bio": {
          "type": "string"
        }
      },
      "required": ["displayName"]
    }
  },
  "firestore": {
    "posts/{postId}": {
      "schema": "Post",
      "description": "Collection of blog posts."
    },
    "users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
