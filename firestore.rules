rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }
    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isVerified() && (
        (request.auth.token.email == 'rk.upk2345678@gmail.com') ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin')
      );
    }
    function isMasterAdmin() {
      return isVerified() && 
             request.auth.token.email == 'rk.upk2345678@gmail.com';
    }
    function isNotSuspended() {
      return isSignedIn() && (
        (request.auth.token.email == 'rk.upk2345678@gmail.com' && request.auth.token.email_verified == true) ||
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('suspended', false) == false
      );
    }
    function isValidId(id) {
      return id is string && id.size() >= 1 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() {
      return request.resource.data;
    }
    function existing() {
      return resource.data;
    }
    function isValidDayKey(dayKey) {
      return dayKey is string && dayKey.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }
    function isValidPresenceWrite(sessionId) {
      return isValidId(sessionId)
        && incoming().keys().hasOnly(['sessionId', 'userId', 'dayKey', 'lastSeenAt', 'updatedAt'])
        && incoming().sessionId == sessionId
        && (incoming().get('userId', null) == null || isValidId(incoming().userId))
        && isValidDayKey(incoming().dayKey)
        && incoming().lastSeenAt is int
        && incoming().updatedAt is int;
    }
    function isValidPublicInteractionCreate() {
      return incoming().keys().hasOnly(['totalInteractions'])
        && incoming().totalInteractions is int
        && incoming().totalInteractions >= 1
        && incoming().totalInteractions <= 25;
    }
    function isValidPublicInteractionIncrement() {
      return incoming().diff(existing()).affectedKeys().hasOnly(['totalInteractions'])
        && incoming().totalInteractions is int
        && existing().get('totalInteractions', 0) is int
        && incoming().totalInteractions > existing().get('totalInteractions', 0)
        && incoming().totalInteractions <= existing().get('totalInteractions', 0) + 25;
    }
    // --- Post Validation ---
    function isValidPost(data) {
      let requiredFields = ['title', 'slug', 'content', 'authorId', 'authorName', 'createdAt', 'updatedAt', 'published'];
      return data.keys().hasAll(requiredFields)
        && data.title is string && data.title.size() <= 200
        && data.slug is string && data.slug.size() <= 200 && data.slug.matches('^[a-z0-9-]+$')
        && data.content is string && data.content.size() <= 50000
        && data.authorId == request.auth.uid
        && data.published is bool
        && (data.get('excerpt', '') is string && data.get('excerpt', '').size() <= 1000)
        && (data.get('category', '') is string && data.get('category', '').size() <= 100)
        && (data.get('coverImage', '') is string && data.get('coverImage', '').size() <= 900000)
        && (data.get('tags', []) is list && data.get('tags', []).size() <= 10)
        && (data.get('likeCount', 0) is int)
        && (data.get('viewCount', 0) is int);
    }
